<Window x:Class="TWChatOverlay.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:primitives="clr-namespace:System.Windows.Controls.Primitives;assembly=PresentationFramework"
        x:Name="RootWindow"
        Visibility="Hidden"
        Title="TW Chat Overlay" Height="230" Width="538"
        MinHeight="100" MinWidth="538"
        WindowStyle="None" AllowsTransparency="True" Topmost="True"
        Background="Transparent" 
        ResizeMode="NoResize">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
        <Style x:Key="TabButtonStyle" TargetType="RadioButton">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontFamily" Value="{Binding CurrentFont, RelativeSource={RelativeSource AncestorType=Window}}"/>
            <Setter Property="Height" Value="30"/>
            <Setter Property="Margin" Value="2,4"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="BtnBorder" 
                            Background="{TemplateBinding Background}"
                            CornerRadius="8" 
                            BorderThickness="1"
                            BorderBrush="Transparent">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>

                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="BtnBorder" Property="Background" Value="#30FFFFFF"/>
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="BtnBorder" Property="Background" Value="#60FFFFFF"/>
                                <Setter TargetName="BtnBorder" Property="BorderBrush" Value="White"/>
                                <Setter Property="FontWeight" Value="Bold"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>
    <Grid Margin="0, 30, 0, 0">
        <Border Background="#EE1A1A1B" 
            CornerRadius="5" 
            BorderBrush="#55FFFFFF" 
            BorderThickness="1"
            HorizontalAlignment="Right" 
            VerticalAlignment="Top" 
            Margin="0,-22,2,0"  
            Padding="10,4"
            Width="200"
            Height="28"
            Panel.ZIndex="999"
            Visibility="{Binding ShowExpTracker, Converter={StaticResource BooleanToVisibilityConverter}}">
            <DockPanel LastChildFill="True" VerticalAlignment="Center" MinWidth="180">

                <Button Content="x" 
                Click="ResetExp_Click" 
                DockPanel.Dock="Right"
                Foreground="#888" Background="Transparent" BorderThickness="0" 
                FontSize="18" Margin="5,-8,0,0" Cursor="Hand" VerticalAlignment="Center"/>

                <TextBlock Text="{Binding TotalExpDisplay}" 
                   Foreground="#FFCC00" 
                   FontSize="13" Margin="0,1,0,0"
                   FontWeight="Bold" 
                   TextAlignment="Left" 
                   HorizontalAlignment="Left" 
                   VerticalAlignment="Center"/>
            </DockPanel>
        </Border>
        <Border x:Name="OuterEdge" Background="Transparent" Padding="5">
            <Border x:Name="MainBorder" TextElement.FontFamily="{Binding Path=CurrentFont, RelativeSource={RelativeSource AncestorType=Window}}"
                Background="#F51E1E1E" CornerRadius="10" 
                BorderThickness="1.5" BorderBrush="#60FFFFFF" ClipToBounds="True">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="42"/>
                        <RowDefinition/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0"
                    Background="#FF332255" 
                    CornerRadius="3,3,0,0"/>

                    <UniformGrid Grid.Row="0" Columns="7">
                        <RadioButton Content="기본" Style="{StaticResource TabButtonStyle}" IsChecked="True" Tag="Basic" Click="Tab_Click"/>
                        <RadioButton Content="팀" Style="{StaticResource TabButtonStyle}" Tag="Team" Click="Tab_Click"/>
                        <RadioButton Content="클럽" Style="{StaticResource TabButtonStyle}" Tag="Club" Click="Tab_Click"/>
                        <RadioButton Content="외치기" Style="{StaticResource TabButtonStyle}" Tag="Shout" Click="Tab_Click"/>
                        <RadioButton Content="시스템" Style="{StaticResource TabButtonStyle}" Tag="System" Click="Tab_Click"/>
                        <RadioButton Content="추가기능" Style="{StaticResource TabButtonStyle}" Tag="Addon" Click="Tab_Click"/>
                        <RadioButton Content="설정" Style="{StaticResource TabButtonStyle}" Tag="Settings" Click="Tab_Click"/>
                    </UniformGrid>

                    <RichTextBox Grid.Row="1" x:Name="LogDisplay" 
                         FontSize="{Binding FontSize}" 
                         FontFamily="{Binding FontFamily}"
                         IsReadOnly="True" 
                         Background="Transparent" 
                         BorderThickness="0" 
                         VerticalScrollBarVisibility="Auto" 
                         Margin="5,5,5,5">
                        <FlowDocument PagePadding="0"/>
                    </RichTextBox>

                    <ScrollViewer Grid.Row="1" x:Name="AddonDisplay" Visibility="Collapsed" VerticalScrollBarVisibility="Auto">
                        <Border Background="#F51E1E1E" Padding="15">
                            <StackPanel>

                                <Border BorderBrush="#33FFFFFF" BorderThickness="0,0,0,1" Margin="0,0,0,15" Padding="0,0,0,15">
                                    <StackPanel>
                                        <TextBlock Text="키워드 알림 설정" Foreground="White" FontSize="16" FontWeight="Bold" Margin="0,0,0,15"/>

                                        <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                            <CheckBox Content="색상 강조" IsChecked="{Binding UseAlertColor}" 
                                  Foreground="White" Margin="0,0,20,0" FontSize="13"/>
                                            <CheckBox Content="알림음 재생" IsChecked="{Binding UseAlertSound}" 
                                  Foreground="White" FontSize="13"/>
                                        </StackPanel>

                                        <TextBlock Text="알림 키워드 입력 (@단어1 @단어2 형식)" Foreground="#AAA" FontSize="12" Margin="0,5,0,5"/>
                                        <TextBox x:Name="KeywordBox" 
                             Text="{Binding KeywordInput, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                             TextChanged="KeywordBox_TextChanged"
                             Background="#333" Foreground="White" BorderBrush="#555" 
                             Padding="10" FontSize="14" AcceptsReturn="True" TextWrapping="Wrap" Height="80"/>
                                        <TextBlock Text="* 입력 시 자동으로 저장됩니다." Foreground="#60FFFFFF" FontSize="11" Margin="0,5,0,0"/>
                                    </StackPanel>
                                </Border>

                                <StackPanel>
                                    <TextBlock Text="경험치 추적" Foreground="White" FontSize="16" FontWeight="Bold" Margin="0,0,0,15"/>

                                    <CheckBox Content="경험치 추적기능 활성화" 
                          IsChecked="{Binding ShowExpTracker, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                          Foreground="White" FontSize="13" Margin="0,0,0,8"/>

                                    <TextBlock Text="* 활성화 시 화면 상단에 실시간 획득량이 표시됩니다." 
                           Foreground="#888" FontSize="11" Margin="0,0,0,0"/>
                                </StackPanel>

                            </StackPanel>
                        </Border>
                    </ScrollViewer>

                    <ScrollViewer Grid.Row="1" x:Name="SettingsDisplay" Visibility="Collapsed" VerticalScrollBarVisibility="Auto">
                        <Border Background="#F51E1E1E" Padding="15">
                            <StackPanel>
                                <TextBlock Text="오버레이 설정" Foreground="White" FontSize="18" FontWeight="Bold" Margin="0,0,0,20"/>

                                <Border BorderBrush="#33FFFFFF" BorderThickness="0,0,0,1" Margin="0,0,0,20" Padding="0,0,0,20">
                                    <StackPanel>
                                        <TextBlock Text="채팅 필터 및 색상" Foreground="#CCC" FontSize="15" FontWeight="Bold" Margin="0,0,0,12"/>

                                        <UniformGrid Columns="2" Margin="5,0,0,0">
                                            <Grid Margin="0,5,15,5">
                                                <CheckBox Content="일반" IsChecked="{Binding ShowNormal}" Foreground="White" VerticalAlignment="Center" HorizontalAlignment="Left"/>
                                                <Button Width="35" Height="18" HorizontalAlignment="Right"
                        Background="{Binding NormalColor}" Click="ColorPick_Click" Tag="Normal" 
                        BorderBrush="White" BorderThickness="1" Cursor="Hand"/>
                                            </Grid>

                                            <Grid Margin="15,5,0,5">
                                                <CheckBox Content="팀" IsChecked="{Binding ShowTeam}" Foreground="White" VerticalAlignment="Center" HorizontalAlignment="Left"/>
                                                <Button Width="35" Height="18" HorizontalAlignment="Right"
                        Background="{Binding TeamColor}" Click="ColorPick_Click" Tag="Team" 
                        BorderBrush="White" BorderThickness="1" Cursor="Hand"/>
                                            </Grid>

                                            <Grid Margin="0,5,15,5">
                                                <CheckBox Content="클럽" IsChecked="{Binding ShowClub}" Foreground="White" VerticalAlignment="Center" HorizontalAlignment="Left"/>
                                                <Button Width="35" Height="18" HorizontalAlignment="Right"
                        Background="{Binding ClubColor}" Click="ColorPick_Click" Tag="Club" 
                        BorderBrush="White" BorderThickness="1" Cursor="Hand"/>
                                            </Grid>

                                            <Grid Margin="15,5,0,5">
                                                <CheckBox Content="외치기" IsChecked="{Binding ShowShout}" Foreground="White" VerticalAlignment="Center" HorizontalAlignment="Left"/>
                                                <Button Width="35" Height="18" HorizontalAlignment="Right"
                        Background="{Binding ShoutColor}" Click="ColorPick_Click" Tag="Shout" 
                        BorderBrush="White" BorderThickness="1" Cursor="Hand"/>
                                            </Grid>

                                            <Grid Margin="0,5,15,5">
                                                <CheckBox Content="시스템" IsChecked="{Binding ShowSystem}" Foreground="White" VerticalAlignment="Center" HorizontalAlignment="Left"/>
                                                <Button Width="35" Height="18" HorizontalAlignment="Right"
                        Background="{Binding SystemColor}" Click="ColorPick_Click" Tag="System" 
                        BorderBrush="White" BorderThickness="1" Cursor="Hand"/>
                                            </Grid>
                                        </UniformGrid>
                                    </StackPanel>
                                </Border>

                                <Border BorderBrush="#33FFFFFF" BorderThickness="0,0,0,1" Margin="0,0,0,20" Padding="0,0,0,20">
                                    <StackPanel>
                                        <TextBlock Text="텍스트 설정" Foreground="#CCC" FontSize="15" FontWeight="Bold" Margin="0,0,0,12"/>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>

                                            <StackPanel Grid.Column="0" Margin="0,0,10,0">
                                                <TextBlock Text="폰트 종류" Foreground="#888" FontSize="12" Margin="0,0,0,5"/>
                                                <ComboBox ItemsSource="{Binding AvailableFonts}" 
                                      SelectedItem="{Binding FontFamily, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                      Height="30" VerticalContentAlignment="Center">
                                                    <ComboBox.ItemTemplate>
                                                        <DataTemplate>
                                                            <TextBlock Text="{Binding}" FontFamily="{Binding}" FontSize="14"/>
                                                        </DataTemplate>
                                                    </ComboBox.ItemTemplate>
                                                </ComboBox>
                                            </StackPanel>

                                            <StackPanel Grid.Column="1" Margin="10,0,0,0">
                                                <TextBlock Text="크기" Foreground="#888" FontSize="12" Margin="0,0,0,5"/>
                                                <DockPanel>
                                                    <TextBlock Text="{Binding FontSize, StringFormat={}{0:F0}}" Foreground="White" Width="25" DockPanel.Dock="Right" TextAlignment="Right" VerticalAlignment="Center"/>
                                                    <Slider Minimum="10" Maximum="40" Value="{Binding FontSize}" TickFrequency="1" IsSnapToTickEnabled="True" VerticalAlignment="Center"/>
                                                </DockPanel>
                                            </StackPanel>
                                        </Grid>
                                    </StackPanel>
                                </Border>

                                <Border Margin="0,0,0,10">
                                    <StackPanel>
                                        <TextBlock Text="위치 설정" Foreground="#CCC" FontSize="15" FontWeight="Bold" Margin="0,0,0,12"/>
                                        <UniformGrid Columns="2">
                                            <StackPanel Margin="0,0,10,0">
                                                <TextBlock Text="X 좌표 (좌우)" Foreground="#888" FontSize="12" Margin="0,0,0,5"/>
                                                <TextBox Text="{Binding LineMarginLeft, UpdateSourceTrigger=LostFocus}" 
                                     Height="28" Background="#333" Foreground="White" BorderBrush="#555"
                                     VerticalContentAlignment="Center" TextAlignment="Center"
                                     PreviewTextInput="NumberOnly_PreviewTextInput" KeyDown="OffsetInput_KeyDown"/>
                                            </StackPanel>
                                            <StackPanel Margin="10,0,0,0">
                                                <TextBlock Text="Y 좌표 (상하)" Foreground="#888" FontSize="12" Margin="0,0,0,5"/>
                                                <TextBox Text="{Binding LineMargin, UpdateSourceTrigger=LostFocus}" 
                                     Height="28" Background="#333" Foreground="White" BorderBrush="#555"
                                     VerticalContentAlignment="Center" TextAlignment="Center"
                                     PreviewTextInput="NumberOnly_PreviewTextInput" KeyDown="OffsetInput_KeyDown"/>
                                            </StackPanel>
                                        </UniformGrid>
                                    </StackPanel>
                                </Border>

                                <UniformGrid Columns="2" Margin="0,20,0,0">
                                    <Button Content="설정 초기화" Height="32" Margin="0,0,5,0" Click="InitSettings_Click" Background="#30FFFFFF" Foreground="White"/>
                                    <Button Content="프로그램 종료" Height="32" Margin="5,0,0,0" Click="ExitApp_Click" Background="#60FF4444" Foreground="White" FontWeight="Bold"/>
                                </UniformGrid>
                            </StackPanel>
                        </Border>
                    </ScrollViewer>
                </Grid>
            </Border>
        </Border>
        <primitives:Thumb Height="8" VerticalAlignment="Top" Cursor="SizeNS" DragDelta="TopResize_DragDelta">
            <primitives:Thumb.Template>
                <ControlTemplate TargetType="primitives:Thumb">
                    <Border Background="Transparent" />
                </ControlTemplate>
            </primitives:Thumb.Template>
        </primitives:Thumb>

        <primitives:Thumb Width="8" HorizontalAlignment="Left" Cursor="SizeWE" DragDelta="LeftResize_DragDelta">
            <primitives:Thumb.Template>
                <ControlTemplate TargetType="primitives:Thumb">
                    <Border Background="Transparent" />
                </ControlTemplate>
            </primitives:Thumb.Template>
        </primitives:Thumb>

        <primitives:Thumb Width="8" HorizontalAlignment="Right" Cursor="SizeWE" DragDelta="RightResize_DragDelta">
            <primitives:Thumb.Template>
                <ControlTemplate TargetType="primitives:Thumb">
                    <Border Background="Transparent" />
                </ControlTemplate>
            </primitives:Thumb.Template>
        </primitives:Thumb>
    </Grid>
</Window>